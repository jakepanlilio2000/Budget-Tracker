<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /expenses/

    # Explicitly serve PWA files directly, bypassing PHP
    RewriteRule ^manifest\.json$ public/manifest.json [L,NC]
    RewriteRule ^sw\.js$ public/sw.js [L,NC]

    # If the request is a real file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Otherwise, route everything to public/index.php
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>